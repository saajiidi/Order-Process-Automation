# Streamlit Secrets Configuration
# Copy this file to secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to git!

# ============================================
# GOOGLE CLOUD / GOOGLE SHEETS CONFIGURATION
# ============================================
GSHEET_URL = "https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?output=csv"
GSHEET_ID = "YOUR_SHEET_ID"
GSHEET_GID = "0"
GDRIVE_FOLDER_ID = "YOUR_DRIVE_FOLDER_ID"

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "your-private-key-id"
private_key = """-----BEGIN RSA PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"""
client_email = "your-service-account@your-project.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"

# ============================================
# WOOCOMMERCE API CONFIGURATION
# ============================================
# Used for both Customer Extraction and Live Dashboard
# Option 1: Top-level keys (for Live Dashboard)
WC_STORE_URL = "https://yourstore.com"
WC_CONSUMER_KEY = "ck_your_consumer_key_here"
WC_CONSUMER_SECRET = "cs_your_consumer_secret_here"
WC_API_VERSION = "wc/v3"

# Optional: Custom meta keys for WhatsApp fields (Customer Extraction)
WC_WHATSAPP_META_KEY = "whatsapp_number"
WC_WHATSAPP_ENABLED_KEY = "whatsapp_enabled"

# Option 2: Nested section (for Customer Extraction tab)
[woocommerce]
store_url = "https://yourstore.com"
consumer_key = "ck_your_consumer_key_here"
consumer_secret = "cs_your_consumer_secret_here"
api_version = "wc/v3"
whatsapp_meta_key = "whatsapp_number"
whatsapp_enabled_key = "whatsapp_enabled"
